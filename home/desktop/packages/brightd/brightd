#!/usr/bin/env python3

import os
import sys
import threading
import argparse
import signal
import socket
import subprocess
import json
import tomllib
import re
from dataclasses import dataclass, field


CONFIG_PATH = os.path.expanduser("~/.config/brightd/config.toml")
SOCKET_DIR = os.path.join(
    os.environ.get("XDG_RUNTIME_DIR", "/tmp"),
    "brightd",
)
SOCKET_PATH = os.path.join(SOCKET_DIR, "brightd.sock")


def run_cmd(argv, timeout=5):
    try:
        return subprocess.run(
            argv,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(argv, 1, "", "timeout")

def clamp(value, min_value, max_value):
    return max(min_value, min(value, max_value))

def send_json(sock, data):
    raw = (json.dumps(data) + "\n").encode()
    sock.sendall(raw)

def recv_json(sock):
    buf = b""
    while b"\n" not in buf:
        chunk = sock.recv(4096)
        if not chunk:
            return None
        buf += chunk
    line, _, _ = buf.partition(b"\n")
    return json.loads(line.decode())

def build_parser():
    parser = argparse.ArgumentParser(prog="brightd")
    subparsers = parser.add_subparsers(dest="mode", required=True)

    worker = subparsers.add_parser("worker")
    worker.add_argument("--config", default=CONFIG_PATH)
    worker.add_argument("--socket", default=SOCKET_PATH)

    ctl = subparsers.add_parser("ctl")
    ctl.add_argument("cmd", choices=["get", "set", "inc", "dec", "reload"])
    ctl.add_argument("monitor", nargs="?", default="all")
    ctl.add_argument("value", nargs="?", type=int)
    ctl.add_argument("--socket", default=SOCKET_PATH)

    watch = subparsers.add_parser("watch")
    watch.add_argument("--socket", default=SOCKET_PATH)

    return parser

def check_ctl_args(args):
    if args.cmd in {"set", "inc", "dec"}:
        if args.value is None:
            print("error: value is required", file=sys.stderr)
            sys.exit(1)
        if args.value < 0 or args.value > 100:
            print("error: invalid value", file=sys.stderr)
            sys.exit(1)

    if args.cmd == "reload":
        if args.monitor != "all" or args.value is not None:
            print("error: too much arguments", file=sys.stderr)
            sys.exit(1)
    if args.cmd == "get" and args.value is not None:
            print("error: too much arguments", file=sys.stderr)
            sys.exit(1)

def load_config(path):
    monitors = {}

    try:
        with open(path, "rb") as f:
            data = tomllib.load(f)
    except FileNotFoundError:
        return monitors
    except tomllib.TOMLDecodeError as e:
        print(f"config error: {e}", file=sys.stderr)
        sys.exit(1)

    for name, item in data.items():
        if not isinstance(item, dict) or not item:
            continue

        device = str(item.get("device", "external")).strip() or "external"

        brightness_data = item.get("brightness", {})
        try:
            min_value = int(brightness_data.get("min", 0))
            max_value = int(brightness_data.get("max", 100))
        except (TypeError, ValueError):
            print(f"config error: invalid brightness values for {name}", file=sys.stderr)
            sys.exit(1)
        if min_value < 0 or max_value > 100 or min_value > max_value:
            print(f"config warning: invalid brightness range for {name}", file=sys.stderr)
            min_value, max_value = 0, 100

        monitors[name] = Monitor(
            name=name,
            device=device,
            brightness=Brightness(
                min=min_value,
                max=max_value,
            ),
        )

    return monitors


@dataclass
class Brightness:
    current: int = 50
    target: int = 50
    revision: int = 0
    min: int = 0
    max: int = 100

@dataclass
class Monitor:
    name: str
    device: str = "external"
    brightness: Brightness = field(default_factory=Brightness)
    bus: str | None = None
    hw_max: int = 0

    def is_external(self):
        return self.device == "external"

    def hw_to_logical(self, hw_value):
        if self.hw_max <= 0:
            return 0

        min_value = self.brightness.min
        max_value = self.brightness.max
        if max_value == min_value:
            return max_value

        scaled = hw_value * 100 / self.hw_max

        logical = (scaled - min_value) * 100 / (max_value - min_value)

        return clamp(round(logical), 0, 100)

    def logical_to_hw(self, logical_value):
        if self.hw_max <= 0:
            return 0

        min_value = self.brightness.min
        max_value = self.brightness.max

        logical_value = clamp(logical_value, 0, 100)

        scaled = min_value + (max_value - min_value) * logical_value / 100

        return round(self.hw_max * scaled / 100)

    def load_brightness(self):
        if self.is_external():
            return self.load_brightness_external()
        return self.load_brightness_internal()

    def load_brightness_internal(self):
        current = run_cmd(["brightnessctl", "-d", self.device, "g"])
        maximum = run_cmd(["brightnessctl", "-d", self.device, "m"])

        if current.returncode != 0 or maximum.returncode != 0:
            return False

        try:
            current_hw = int(current.stdout.strip())
            self.hw_max = int(maximum.stdout.strip())
        except ValueError:
            return False

        self.brightness.current = self.hw_to_logical(current_hw)
        return True

    def load_brightness_external(self):
        if self.bus is None:
            return False

        result = run_cmd([
            "ddcutil",
            "--bus",
            self.bus,
            "--sleep-multiplier",
            ".2",
            "getvcp",
            "10",
            "--terse"
        ])

        if result.returncode != 0:
            return False

        parts = result.stdout.strip().split()
        if len(parts) != 5 or parts[0] != "VCP" or parts[1] != "10":
            return False

        try:
            current_hw = int(parts[3])
            self.hw_max = int(parts[4])
            self.brightness.current = self.hw_to_logical(current_hw)
        except ValueError:
            return False

        return True

    def apply_brightness(self, value):
        if self.is_external():
            return self.apply_brightness_external(value)
        return self.apply_brightness_internal(value)

    def apply_brightness_internal(self, value):
        hw_value = self.logical_to_hw(value)

        result = run_cmd([
            "brightnessctl",
            "-q",
            "-d",
            self.device,
            "set",
            str(hw_value),
        ])

        return result.returncode == 0

    def apply_brightness_external(self, value):
        if self.bus is None:
            return False

        hw_value = self.logical_to_hw(value)

        result = run_cmd([
            "ddcutil",
            "--bus",
            self.bus,
            "--sleep-multiplier",
            ".1",
            "setvcp",
            "10",
            str(hw_value),
            "--noverify",
        ])

        return result.returncode == 0


def detect_external_monitor_buses():
    result = run_cmd(["ddcutil", "detect"])
    if result.returncode != 0:
        print("error: failed to run ddcutil detect", file=sys.stderr)
        if result.stderr:
            print("ddcutil: ", result.stderr.strip(), file=sys.stderr)
        return {}

    buses = {}
    name = None
    bus = None
    for raw_line in result.stdout.splitlines():
        line = raw_line.strip()

        if line.startswith("Display "):
            if name is not None and bus is not None:
                buses[name] = bus
            bus = None
            name = None
            continue

        if line.startswith("I2C bus:"):
            match = re.search(r"/dev/i2c-(\d+)", line)
            if match:
                bus = match.group(1)
            continue

        if line.startswith("DRM_connector:"):
            name = line.split(":", 1)[1].strip()
            name = re.sub(r"^card\d+-", "", name)

    if name is not None and bus is not None:
        buses[name] = bus

    return buses

class Brightd:
    def __init__(self, config_path, socket_path):
        self.config_path = config_path
        self.socket_path = socket_path
        self.monitors = {}
        self.watchers = []
        self.sock = None
        self.hotplug_proc = None
        self.lock = threading.Lock()
        self.watch_lock = threading.Lock()
        self.cond = threading.Condition(self.lock)

    def monitor_state(self, monitor):
        return {
            "target": monitor.brightness.target,
            "current": monitor.brightness.current,
            "revision": monitor.brightness.revision,
        }

    def monitor_states(self, names=None):
        if names is None:
            names = self.monitors.keys()

        return {
            name: self.monitor_state(self.monitors[name])
            for name in names
            if name in self.monitors
        }

    def notify_watchers(self, phase, monitors):
        if not monitors:
            return

        event = {
            "ok": True,
            "event": "brightness",
            "phase": phase,
            "monitors": monitors,
        }
        watchers = []

        with self.watch_lock:
            for conn in self.watchers:
                try:
                    send_json(conn, event)
                except OSError:
                    continue
                watchers.append(conn)
            self.watchers = watchers

    def reload_monitors(self):
        configured_monitors = load_config(self.config_path)
        detected_monitor_buses = detect_external_monitor_buses()
        monitors = {}

        for monitor in configured_monitors.values():
            if monitor.is_external():
                monitor.bus = detected_monitor_buses.get(monitor.name)
                if monitor.bus is None:
                    continue
            if not monitor.load_brightness():
                continue
            monitors[monitor.name] = monitor

        for name, bus in detected_monitor_buses.items():
            if name in configured_monitors:
                continue
            monitor = Monitor(
                name=name,
                bus=bus,
            )
            if not monitor.load_brightness():
                continue
            monitors[name] = monitor

        with self.cond:
            for name, monitor in monitors.items():
                if name not in self.monitors:
                    print(
                        f"info: add monitor {name} "
                        f"({monitor.bus or monitor.device}) "
                        f"[{monitor.brightness.min} {monitor.brightness.max}]"
                    )
                    monitor.brightness.target = monitor.brightness.current
                else:
                    monitor.brightness.target = self.monitors[name].brightness.target
                    monitor.brightness.revision = self.monitors[name].brightness.revision
            self.monitors = monitors
            monitor_states = self.monitor_states()
            self.cond.notify()

        self.notify_watchers("snapshot", monitor_states)

    def get_brightness(self, name):
        with self.lock:
            if name == "all":
                return self.monitor_states()

            monitor = self.monitors.get(name)
            if monitor is not None:
                return { name: self.monitor_state(monitor) }

            return {}

    def set_brightness(self, name, behaviour, value):
        op = {
            "set": lambda _: value,
            "inc": lambda x: x + value,
            "dec": lambda x: x - value,
        }[behaviour]

        with self.cond:
            if not self.monitors:
                return False, "no monitors available", {}

            if name == "all":
                target = min(monitor.brightness.target for monitor in self.monitors.values())
                target = clamp(op(target), 0, 100)

                changed = []
                for monitor in self.monitors.values():
                    if monitor.brightness.target != target:
                        monitor.brightness.target = target
                        monitor.brightness.revision += 1
                        changed.append(monitor.name)

                self.cond.notify()
                return True, None, self.monitor_states(changed)

            monitor = self.monitors.get(name)
            if monitor is not None:
                target = clamp(op(monitor.brightness.target), 0, 100)
                changed = []

                if monitor.brightness.target != target:
                    monitor.brightness.target = target
                    monitor.brightness.revision += 1
                    changed.append(monitor.name)

                self.cond.notify()
                return True, None, self.monitor_states(changed)

            return False, f"monitor not found: {name}", {}

    def writer_loop(self):
        while True:
            with self.cond:
                while True:
                    outdated = None

                    for monitor in self.monitors.values():
                        if monitor.brightness.current != monitor.brightness.target:
                            outdated = (monitor, monitor.brightness.target)
                            break

                    if outdated is not None:
                        break

                    self.cond.wait()

            monitor, target = outdated
            ok = monitor.apply_brightness(target)
            if not ok:
                print(f"error: failed to apply brightness for {monitor.name}", file=sys.stderr)
                self.reload_monitors()
                continue

            with self.cond:
                monitor_states = {}
                current_monitor = self.monitors.get(monitor.name)
                if monitor is current_monitor:
                    monitor.brightness.current = target
                    monitor_states = {
                        monitor.name: self.monitor_state(monitor)
                    }

            self.notify_watchers("applied", monitor_states)

    def hotplug_loop(self):
        try:
            self.hotplug_proc = subprocess.Popen(
                ["udevadm", "monitor", "--udev", "--property", "--subsystem-match=drm"],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                bufsize=1,
            )
        except Exception as e:
            print(f"error: failed to start udev monitor: {e}", file=sys.stderr)
            return

        if self.hotplug_proc.stdout is None:
            print("error: failed to read udev monitor stdout", file=sys.stderr)
            return

        for line in self.hotplug_proc.stdout:
            if line.strip() == "HOTPLUG=1":
                print("info: drm hotplug event", file=sys.stderr)
                self.reload_monitors()

    def handle(self, request):
        if request["cmd"] == "reload":
            self.reload_monitors()
            return { "ok": True }

        if request["cmd"] == "get":
            result = self.get_brightness(request["monitor"])
            ret = {
                "ok": result != {},
                "monitors": result
            }
            if not ret["ok"]:
                ret["error"] = f"monitor not found: {request['monitor']}"
            return ret

        if request["cmd"] in { "set", "inc", "dec" }:
            ok, error, monitors = self.set_brightness(
                request["monitor"],
                request["cmd"],
                request["value"],
            )
            self.notify_watchers("target", monitors)
            return { "ok": ok, "error": error }

        return { "ok": False, "error": f"unknown command: {request['cmd']}" }

    def handle_watch(self, conn):
        with self.watch_lock:
            self.watchers.append(conn)

        with self.lock:
            monitors = self.monitor_states()

        try:
            send_json(conn, {
                "ok": True,
                "event": "brightness",
                "phase": "snapshot",
                "monitors": monitors,
            })
        except OSError:
            with self.watch_lock:
                try:
                    self.watchers.remove(conn)
                except ValueError:
                    pass
            return

        try:
            while conn.recv(4096):
                pass
        except OSError:
            pass
        finally:
            with self.watch_lock:
                try:
                    self.watchers.remove(conn)
                except ValueError:
                    pass

    def handle_connection(self, conn):
        with conn:
            try:
                data = recv_json(conn)
            except json.JSONDecodeError:
                send_json(conn, {"ok": False, "error": "invalid json"})
                return

            if data is None:
                return

            if data.get("mode") == "watch":
                self.handle_watch(conn)
                return

            if data.get("mode") != "ctl":
                send_json(conn, {"ok": False, "error": f"unknown mode: {data.get('mode')}"})
                return

            res = self.handle(data)
            send_json(conn, res)

    def run(self):
        os.makedirs(os.path.dirname(self.socket_path), exist_ok=True)
        self.reload_monitors()

        try:
            os.unlink(self.socket_path)
        except FileNotFoundError:
            pass

        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.bind(self.socket_path)

        writer = threading.Thread(target=self.writer_loop, daemon=True)
        writer.start()
        hotplug = threading.Thread(target=self.hotplug_loop, daemon=True)
        hotplug.start()

        self.sock.listen()

        print("info: worker listening on", self.socket_path)

        try:
            while True:
                conn, _ = self.sock.accept()
                thread = threading.Thread(
                    target=self.handle_connection,
                    args=(conn,),
                    daemon=True,
                )
                thread.start()
        except (KeyboardInterrupt, SystemExit, OSError):
            pass
        finally:
            if self.hotplug_proc is not None:
                try:
                    self.hotplug_proc.terminate()
                except OSError:
                    pass

            with self.watch_lock:
                watchers = self.watchers
                self.watchers = []

            for conn in watchers:
                try:
                    conn.close()
                except OSError:
                    pass

            if self.sock is not None:
                try:
                    self.sock.close()
                except OSError:
                    pass

            try:
                os.unlink(self.socket_path)
            except FileNotFoundError:
                pass


def run_worker(args):
    brightd = Brightd(args.config, args.socket)
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
    brightd.run()

def run_ctl(args):
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)

    try:
        sock.connect(args.socket)
    except FileNotFoundError:
        print("error: brightd socket not found", file=sys.stderr)
        sys.exit(1)
    except ConnectionRefusedError:
        print("error: brightd is not running", file=sys.stderr)
        sys.exit(1)

    with sock:
        send_json(sock, vars(args))
        res = recv_json(sock)

    if res is None:
        print("error: no response from worker", file=sys.stderr)
        sys.exit(1)

    if args.cmd == "get":
        print(json.dumps(res, indent=2))
        return

    if res.get("ok"):
        print("ok")
        return

    print(f"error: {res.get('error', 'request failed')}", file=sys.stderr)
    sys.exit(1)

def run_watch(args):
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)

    try:
        sock.connect(args.socket)
    except FileNotFoundError:
        print("error: brightd socket not found", file=sys.stderr)
        sys.exit(1)
    except ConnectionRefusedError:
        print("error: brightd is not running", file=sys.stderr)
        sys.exit(1)

    with sock, sock.makefile() as f:
        send_json(sock, vars(args))

        for line in f:
            try:
                data = json.loads(line)
            except json.JSONDecodeError:
                print("error: invalid response from worker", file=sys.stderr)
                sys.exit(1)

            if not data.get("ok"):
                print(f"error: {data.get('error', 'request failed')}", file=sys.stderr)
                sys.exit(1)

            print(json.dumps(data), flush=True)

def main():
    try:
        args = build_parser().parse_args()

        if args.mode == "worker":
            run_worker(args)
            return

        if args.mode == "ctl":
            check_ctl_args(args)
            run_ctl(args)
            return

        if args.mode == "watch":
            run_watch(args)
            return
    except KeyboardInterrupt:
        return


if __name__ == "__main__":
    main()
