#!/usr/bin/env bash
set -euo pipefail

operation=$1
workspace=$2

if (( workspace < 1 || workspace > 10 )); then
  echo "workspace must be 1..10" >&2
  exit 1
fi

active_id=$(hyprctl -j activeworkspace | jq -r '.id')
base=$(( (active_id - 1) / 10 * 10 ))
workspace_id=$(( base + workspace ))

echo "Final Operation: $operation to $workspace_id"

case "$operation" in
  switch)
    hyprctl dispatch focusworkspaceoncurrentmonitor "$workspace_id"
    ;;
  move)
    hyprctl --batch \
      "dispatch moveworkspacetomonitor $workspace_id current; \
       dispatch movetoworkspace $workspace_id"
    ;;
  *)
    echo "unknown operation: $operation" >&2
    exit 1
    ;;
esac
