#!/usr/bin/env bash
set -euo pipefail

force=0
if [[ "${1:-}" == "--force" ]]; then
  force=1
fi

json="$(hyprctl activewindow -j)"
cls="$(jq -r '.class // ""' <<<"$json")"
pid="$(jq -r '.pid // empty' <<<"$json")"

if [[ "$cls" == "Steam" ]]; then
  xdotool getactivewindow windowunmap
  exit 0
fi

if [[ "$force" -eq 1 ]]; then
  if [[ -n "${pid:-}" && "$pid" =~ ^[0-9]+$ && "$pid" -gt 1 ]]; then
    kill -TERM "$pid" 2>/dev/null || true
    sleep 0.15
    kill -KILL "$pid" 2>/dev/null || true
  else
    hyprctl dispatch killactive ""
  fi
else
  hyprctl dispatch killactive ""
fi
