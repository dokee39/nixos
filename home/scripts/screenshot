#!/usr/bin/env bash
# Screenshot script with dynamic window sizing using slurp metadata

mode=$1

mkdir -p /tmp/screenshot

# Generate human-readable timestamp filename
timestamp=$(date +"%Y%m%d-%H%M%S")
case ${mode} in 
    area)
        screenshot_file=$(mktemp -u "/tmp/screenshot/screenshot-area-${timestamp}-XXXXXX.png")
    ;;
    show)
        screenshot_file=$(mktemp -u "/tmp/screenshot/screenshot-show-${timestamp}-XXXXXX.png")
    ;;
    window)
        screenshot_file=$(mktemp -u "/tmp/screenshot/screenshot-window-${timestamp}-XXXXXX.png")
    ;;
    monitor)
        screenshot_file=$(mktemp -u "/tmp/screenshot/screenshot-monitor-${timestamp}-XXXXXX.png")
    ;;
    *)
        echo "Usage: $0 [area|show|window|monitor]"
    ;;
esac

case ${mode} in 
    area|show) 
        # Get user-selected area with coordinates and dimensions
        selected_area=$(slurp -b 19172480 -c c4a7e780 -w 2 -f "%x %y %w %h")
        slurp_exit_code=$?

        # Exit immediately if user cancels selection
        if (( slurp_exit_code != 0 )); then
            exit 1
        fi

        # Parse slurp output into variables
        read -r pos_x pos_y width height <<< "${selected_area}"

        # Capture screenshot with error handling
        if ! grim -l 9 -g "${pos_x},${pos_y} ${width}x${height}" - \
            | tee >(wl-copy) > "${screenshot_file}"; then
            notify-send "Error: Screenshot capture failed. Check grim installation."
            exit 2
        fi
    ;;
esac

case ${mode} in 
    window) 
        grimblast --freeze copysave active "${screenshot_file}"
    ;;
    monitor) 
        grimblast --freeze copysave output "${screenshot_file}"
    ;;
esac

# Validate file creation
if ! [[ -s "${screenshot_file}" ]]; then
    notify-send "Error: Empty screenshot file generated."
    rm -f "${screenshot_file}"
    exit 3
fi

case ${mode} in 
    show)
        # Calculate window size with 0px decoration padding
        read -r pos_x_offset pos_y_offset <<< $(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | "\(.x) \(.y)"')
        if [[ "$width" =~ ^[0-9]+$ && "$height" =~ ^[0-9]+$ ]]; then
            # hyprctl dispatch exec "[float; pin; keepaspectratio; move onscreen $((pos_x - pos_x_offset)) $((pos_y - pos_y_offset))] imv -W ${width} -H ${height} ${screenshot_file} &> /dev/null"
            hyprctl dispatch exec "[float; pin; keepaspectratio; move onscreen $((pos_x - pos_x_offset)) $((pos_y - pos_y_offset)); size ${width} ${height}] qview ${screenshot_file} &> /dev/null"
        else
            notify-send "Warning: Invalid dimensions, using default size"
            # hyprctl dispatch exec "[float; pin; keepaspectratio; move onscreen $((pos_x - pos_x_offset)) $((pos_y - pos_y_offset))] imv ${screenshot_file} &> /dev/null"
            hyprctl dispatch exec "[float; pin; keepaspectratio; move onscreen $((pos_x - pos_x_offset)) $((pos_y - pos_y_offset))] qview ${screenshot_file} &> /dev/null"
        fi
    ;;
    *)
        notify-send -t 2000 -u low "screenshot created:" "${screenshot_file}"
    ;;
esac

